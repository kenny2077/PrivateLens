# PrivateLens local configuration
# Copy to .env only when you need to override defaults.

# Runtime data stays outside the repository by default.
# PRIVATELENS_DATA_DIR=/Users/you/.privatelens
# PRIVATELENS_DB_PATH=/Users/you/.privatelens/privatelens.db
# PRIVATELENS_THUMBNAIL_DIR=/Users/you/.privatelens/thumbnails
# PRIVATELENS_MODEL_CACHE_DIR=/Users/you/.privatelens/models

# Local models
PRIVATELENS_CLIP_MODEL=ViT-B-32-quickgelu
PRIVATELENS_CLIP_PRETRAINED=openai
PRIVATELENS_FACE_MODEL=buffalo_l
PRIVATELENS_VLM_MODEL=qwen3-vl:2b-instruct-q8_0
PRIVATELENS_OLLAMA_URL=http://localhost:11434

# MacBook-friendly indexing defaults
PRIVATELENS_BATCH_SIZE=2
PRIVATELENS_THUMBNAIL_SIZE=256
PRIVATELENS_MAX_IMAGE_SIZE=1024
PRIVATELENS_SKIP_DUPLICATES=true

# Privacy
PRIVATELENS_LOCAL_ONLY=true
PRIVATELENS_SENSITIVE_SCAN=true
# Generate a Fernet key before enabling encrypted sensitive metadata.
# PRIVATELENS_ENCRYPTION_KEY=

# Search
PRIVATELENS_DEFAULT_SEARCH_LIMIT=50
PRIVATELENS_VECTOR_SEARCH_LIMIT=200
PRIVATELENS_RERANK_TOP_K=30

# Optional integrations
# PRIVATELENS_ANYTHINGLLM_URL=http://localhost:3001
# PRIVATELENS_ANYTHINGLLM_API_KEY=
# PRIVATELENS_ANYTHINGLLM_WORKSPACE=privatelens
# PRIVATELENS_IMMICH_DB_URL=
